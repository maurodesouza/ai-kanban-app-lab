      "updated": 1775848210295,
      "link": null,
      "locked": false,
      "text": "    <Kanban.Container>\n      <Kanban.Header>\n        <Kanban.Title>AI Todo App</Kanban.Title>\n\n        <Kanban.Filter />\n      </Kanban.Header>\n\n      <Kanban.Content>\n        <Kanban.Columns\n          render={column => {\n            return (\n              <Kanban.Column.Container>\n                <Kanban.Column.Header>\n                  <Kanban.Column.Title>{column.title}</Kanban.Column.Title>\n                </Kanban.Column.Header>\n\n                <Kanban.Column.Content>\n                  <Kanban.Tasks\n                    columnId={column.id}\n                    render={task => {\n                      return (\n                        <Kanban.Task.Container>\n                          <Kanban.Task.Header>\n                            <Kanban.Task.Title>{task.title}</Kanban.Task.Title>\n                          </Kanban.Task.Header>\n\n                          <Kanban.Task.Footer>\n                            <Kanban.Task.DeleteAction taskId={task.id} />\n                            <Kanban.Task.EditAction taskId={task.id} />\n                          </Kanban.Task.Footer>\n                        </Kanban.Task.Container>\n                      );\n                    }}\n                  />\n                </Kanban.Column.Content>\n              </Kanban.Column.Container>\n            );\n          }}\n        />\n      </Kanban.Content>\n    </Kanban.Container>",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    <Kanban.Container>\n      <Kanban.Header>\n        <Kanban.Title>AI Todo App</Kanban.Title>\n\n        <Kanban.Filter />\n      </Kanban.Header>\n\n      <Kanban.Content>\n        <Kanban.Columns\n          render={column => {\n            return (\n              <Kanban.Column.Container>\n                <Kanban.Column.Header>\n                  <Kanban.Column.Title>{column.title}</Kanban.Column.Title>\n                </Kanban.Column.Header>\n\n                <Kanban.Column.Content>\n                  <Kanban.Tasks\n                    columnId={column.id}\n                    render={task => {\n                      return (\n                        <Kanban.Task.Container>\n                          <Kanban.Task.Header>\n                            <Kanban.Task.Title>{task.title}</Kanban.Task.Title>\n                          </Kanban.Task.Header>\n\n                          <Kanban.Task.Footer>\n                            <Kanban.Task.DeleteAction taskId={task.id} />\n                            <Kanban.Task.EditAction taskId={task.id} />\n                          </Kanban.Task.Footer>\n                        </Kanban.Task.Container>\n                      );\n                    }}\n                  />\n                </Kanban.Column.Content>\n              </Kanban.Column.Container>\n            );\n          }}\n        />\n      </Kanban.Content>\n    </Kanban.Container>",
      "autoResize": true,
      "lineHeight": 1.25
    },
