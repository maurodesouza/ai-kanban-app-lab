    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "react-twc": "^1.4.0",
    "tailwind-merge": "^2.5.4",
    "tailwind-variants": "^0.3.0",
    "zod": "^3.23.8",
    "next": "15.2.4"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "cypress": "^13.17.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.2.4",
